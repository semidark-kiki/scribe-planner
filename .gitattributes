# Normalize line endings
* text=auto

# Python files should always use LF
*.py text eol=lf

# Shell scripts should use LF
*.sh text eol=lf

# Markdown files should use LF
*.md text eol=lf

# JSON files should use LF
*.json text eol=lf

# YAML files should use LF
*.yml text eol=lf
*.yaml text eol=lf
